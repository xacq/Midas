          <EntitySet Name="viPersonaListar" EntityType="Self.viPersonaListar" store:Type="Views" store:Schema="dbo">
            <DefiningQuery>SELECT 
    [viPersonaListar].[idPersona] AS [idPersona], 
    [viPersonaListar].[idTipoDocumento] AS [idTipoDocumento], 
    [viPersonaListar].[paterno] AS [paterno], 
    [viPersonaListar].[materno] AS [materno], 
