          <EntitySet Name="viMenu" EntityType="Self.viMenu" store:Type="Views" store:Schema="dbo">
            <DefiningQuery>SELECT 
    [viMenu].[idMenu] AS [idMenu], 
    [viMenu].[menu] AS [menu], 
    [viMenu].[nombre_Elemento] AS [nombre_Elemento]
    FROM [dbo].[viMenu] AS [viMenu]</DefiningQuery>
